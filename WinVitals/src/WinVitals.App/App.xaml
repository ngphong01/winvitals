<Application x:Class="WinVitals.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WinVitals.App.Converters">
        <Application.Resources>
                <ResourceDictionary>
                        <ResourceDictionary.MergedDictionaries>
                                <ResourceDictionary Source="Themes/Colors.xaml"/>
                                <ResourceDictionary Source="Themes/Controls.xaml"/>
                        </ResourceDictionary.MergedDictionaries>

                        <!-- Converters (must stay in App.xaml for StaticResource resolution) -->
                        <conv:BoolToVisConverter x:Key="BoolToVis"/>
                        <conv:NonEmptyVisConverter x:Key="NonEmptyVis"/>
                        <conv:InvertBoolConverter x:Key="InvertBool"/>

                        <!-- Card Border -->
                        <Style TargetType="Border"
                                        x:Key="Card">
                                <Setter Property="Background"
                                                Value="{DynamicResource AppCard}"/>
                                <Setter Property="CornerRadius"
                                                Value="8"/>
                                <Setter Property="Padding"
                                                Value="16"/>
                        </Style>

                        <!-- Implicit page-level styles -->
                        <Style TargetType="Page">
                                <Setter Property="Background"
                                                Value="{DynamicResource AppBackground}"/>
                                <Setter Property="FontFamily"
                                                Value="Segoe UI, sans-serif"/>
                        </Style>
                        <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                                Value="{DynamicResource AppText}"/>
                                <Setter Property="FontFamily"
                                                Value="Segoe UI, sans-serif"/>
                        </Style>
                        <Style TargetType="StatusBar">
                                <Setter Property="Foreground"
                                                Value="{DynamicResource AppText}"/>
                                <Setter Property="Background"
                                                Value="Transparent"/>
                        </Style>
                </ResourceDictionary>
        </Application.Resources>
</Application>
