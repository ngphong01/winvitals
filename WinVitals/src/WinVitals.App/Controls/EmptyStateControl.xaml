<UserControl x:Class="WinVitals.App.Controls.EmptyStateControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="Auto"
             Width="Auto">
    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="48,32">
            <!-- Vector icon using Segoe MDL2 Assets -->
            <TextBlock Text="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}, Path=IconGlyph}"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="48"
                       Foreground="#585B70"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>
            <TextBlock Text="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}, Path=Title}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#CDD6F4"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"/>
            <TextBlock Text="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}, Path=Description}"
                       FontSize="13"
                       Foreground="#A6ADC8"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="0,10,0,0"
                       MaxWidth="380"
                       LineHeight="20"/>
            <Button Content="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}, Path=ActionText}"
                    Style="{StaticResource PrimaryBtn}"
                    Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}, Path=ActionCommand}"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0"
                    Padding="20,8"
                    Visibility="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}, Path=ActionText, Converter={StaticResource NonEmptyVis}}"/>
        </StackPanel>
    </Grid>
</UserControl>
