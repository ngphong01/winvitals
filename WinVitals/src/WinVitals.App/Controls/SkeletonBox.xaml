<UserControl x:Class="WinVitals.App.Controls.SkeletonBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="Auto"
        Height="Auto">
    <UserControl.Resources>
        <LinearGradientBrush x:Key="ShimmerBrush"
                StartPoint="0,0"
                EndPoint="1,0">
            <GradientStop Color="#20FFFFFF"
                    Offset="0"/>
            <GradientStop Color="#15FFFFFF"
                    Offset="0.5"/>
            <GradientStop Color="#20FFFFFF"
                    Offset="1"/>
        </LinearGradientBrush>
        <Storyboard x:Key="ShimmerAnim"
                RepeatBehavior="Forever"
                AutoReverse="False">
            <DoubleAnimation Storyboard.TargetProperty="(Shape.Fill).(LinearGradientBrush.Transform).(TranslateTransform.X)"
                             From="-400"
                    To="400"
                    Duration="0:0:1.5"/>
        </Storyboard>
    </UserControl.Resources>
    <Border Background="#2A2A3C"
            CornerRadius="4"
            ClipToBounds="True">
        <Border x:Name="ShimmerBar"
                Background="{StaticResource ShimmerBrush}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Width="400">
            <Border.RenderTransform>
                <TranslateTransform/>
            </Border.RenderTransform>
        </Border>
    </Border>
</UserControl>
