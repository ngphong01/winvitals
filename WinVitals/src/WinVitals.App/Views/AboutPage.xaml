<Page x:Class="WinVitals.App.Views.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="About">
        <ScrollViewer>
                <StackPanel Margin="24"
                            MaxWidth="820"
                            HorizontalAlignment="Left">
                        <Border Style="{StaticResource Card}"
                                Padding="28"
                                Margin="0,0,0,16">
                                <Grid>
                                        <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Width="80"
                                                Height="80"
                                                CornerRadius="16"
                                                Background="#89B4FA"
                                                Margin="0,0,24,0">
                                                <TextBlock Text="W"
                                                           FontSize="48"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="White"/>
                                        </Border>
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="WinVitals"
                                                           FontSize="32"
                                                           FontWeight="Bold"
                                                           />
                                                <TextBlock FontSize="13"
                                                                Margin="0,2,0,0"
                                                                Foreground="{DynamicResource AppTextMuted}">
                            <Run Text="by "/><Run Text="{Binding Author, Mode=OneWay}"
                                                                        FontWeight="SemiBold"
                                                                        Foreground="#89B4FA"/>
                                                </TextBlock>
                                                <TextBlock Text="Windows health &amp; cleanup suite"
                                                           Foreground="{DynamicResource AppTextMuted}"
                                                           FontSize="14"/>
                                                <StackPanel Orientation="Horizontal"
                                                            Margin="0,10,0,0">
                                                        <TextBlock Text="Version"
                                                                   Foreground="{DynamicResource AppTextMuted}"/>
                                                        <TextBlock Text="{Binding Version}"
                                                                   FontWeight="SemiBold"
                                                                   
                                                                   Margin="6,0,20,0"/>
                                                        <TextBlock Text=".NET "
                                                                   Foreground="{DynamicResource AppTextMuted}"/>
                                                        <TextBlock Text="{Binding DotNetVersion}"
                                                                   FontWeight="SemiBold"
                                                                   />
                                                </StackPanel>
                                        </StackPanel>
                                </Grid>
                        </Border>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,16">
                                <Button Content="â¬† Check for updates"
                                        Style="{StaticResource PrimaryBtn}"
                                        Margin="0,0,8,0"
                                        Padding="10,6"
                                        Command="{Binding CheckUpdateCommand}"
                                        IsEnabled="{Binding IsCheckingUpdate, Converter={StaticResource InvertBool}}"/>
                                <Button Content="â¬‡ Download update"
                                        Style="{StaticResource PrimaryBtn}"
                                        Margin="0,0,8,0"
                                        Padding="10,6"
                                        Command="{Binding DownloadUpdateCommand}"
                                        Visibility="{Binding LatestVersion, Converter={StaticResource NonEmptyVis}}"/>
                                <Button Content="Report issue"
                                        Style="{StaticResource SecondaryBtn}"
                                        Margin="0,0,8,0"
                                        Padding="10,6"
                                        Command="{Binding OpenUrlCommand}"
                                        CommandParameter="https://github.com"/>
                                <Button Content="View source"
                                        Style="{StaticResource SecondaryBtn}"
                                        Padding="10,6"
                                        Command="{Binding OpenUrlCommand}"
                                        CommandParameter="https://github.com"/>
                        </StackPanel>

                        <!-- Update status -->
                        <Border Style="{StaticResource Card}"
                                Padding="20"
                                Margin="0,0,0,12"
                                Visibility="{Binding UpdateStatusText, Converter={StaticResource NonEmptyVis}}">
                                <StackPanel>
                                        <TextBlock Text="{Binding UpdateStatusText}"
                                                   
                                                   FontSize="14"
                                                   FontWeight="SemiBold"/>
                                        <ProgressBar Value="{Binding DownloadProgress}"
                                                     Maximum="100"
                                                     Height="6"
                                                     Margin="0,10,0,0"
                                                     Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BoolToVis}}"
                                                     Foreground="#60A5FA"/>
                                        <Button Content="ðŸ”„ Restart now"
                                                Style="{StaticResource PrimaryBtn}"
                                                Command="{Binding RestartNowCommand}"
                                                Margin="0,10,0,0"
                                                HorizontalAlignment="Left"
                                                Visibility="{Binding HasUpdateReady, Converter={StaticResource BoolToVis}}"
                                                Padding="12,6"/>
                                        <Border Background="#20FFFFFF"
                                                CornerRadius="4"
                                                Padding="12"
                                                Margin="0,10,0,0"
                                                Visibility="{Binding ReleaseNotes, Converter={StaticResource NonEmptyVis}}">
                                                <StackPanel>
                                                        <TextBlock Text="Release notes"
                                                                   FontWeight="SemiBold"
                                                                   
                                                                   Margin="0,0,0,6"/>
                                                        <TextBlock Text="{Binding ReleaseNotes}"
                                                                   TextWrapping="Wrap"
                                                                   FontFamily="Cascadia Mono, Consolas"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource AppTextMuted}"/>
                                                </StackPanel>
                                        </Border>
                                </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}"
                                Padding="20"
                                Margin="0,0,0,12">
                                <StackPanel>
                                        <TextBlock Text="Changelog"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   
                                                   Margin="0,0,0,10"/>
                                        <TextBlock Text="{Binding Changelog}"
                                                   FontFamily="Cascadia Mono, Consolas"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource AppTextMuted}"
                                                   TextWrapping="Wrap"/>
                                </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}"
                                Padding="20"
                                Margin="0,0,0,12">
                                <StackPanel>
                                        <TextBlock Text="Open-source dependencies"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   
                                                   Margin="0,0,0,10"/>
                                        <ItemsControl ItemsSource="{Binding OpenSource}">
                                                <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                                <TextBlock Text="{Binding}"
                                                                           Foreground="{DynamicResource AppTextMuted}"
                                                                           Margin="0,3"/>
                                                        </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}"
                                Padding="20"
                                Margin="0,0,0,32">
                                <StackPanel>
                                        <TextBlock Text="License"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   
                                                   Margin="0,0,0,10"/>
                                        <TextBlock Text="{Binding LicenseText}"
                                                   FontFamily="Cascadia Mono, Consolas"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource AppTextMuted}"
                                                   TextWrapping="Wrap"/>
                                </StackPanel>
                        </Border>
                </StackPanel>
        </ScrollViewer>
</Page>
