<Page x:Class="WinVitals.App.Views.CleanPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="clr-namespace:WinVitals.App.Converters"
      xmlns:svc="clr-namespace:WinVitals.App.Services"
      xmlns:enums="clr-namespace:WinVitals.Core;assembly=WinVitals.Core"
      xmlns:system="clr-namespace:System;assembly=System.Runtime"
      Title="Clean">
        <Page.Resources>
                <conv:BytesToHumanConverter x:Key="BytesToHuman"/>
                <conv:RiskToBrushConverter x:Key="RiskBrush"/>
                <conv:EqIntConverter x:Key="EqInt"/>
                <conv:GreaterThanConverter x:Key="GreaterThan"/>
                <conv:LessThanConverter x:Key="LessThan"/>
                <conv:InvertBoolConverter x:Key="InvertBool"/>
                <conv:InvertVisConverter x:Key="InvertVis"/>
                <conv:EnumEqConverter x:Key="EnumEq"/>
                <ObjectDataProvider x:Key="PresetValues"
                                    MethodName="GetValues"
                                    ObjectType="{x:Type system:Enum}">
                        <ObjectDataProvider.MethodParameters>
                                <x:Type TypeName="enums:ScanPreset"/>
                        </ObjectDataProvider.MethodParameters>
                </ObjectDataProvider>
        </Page.Resources>

        <Grid Margin="24">
                <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Margin="0,0,0,16">
                        <TextBlock Text="{svc:Loc Clean_Title}"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   />
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,12,0,0">
                                <TextBlock Text="{svc:Loc Clean_StepPreset}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppTextMuted}"
                                           Margin="0,0,16,0"/>
                                <TextBlock Text="&#xE0AB;"
                                           FontFamily="{DynamicResource IconFont}"
                                           FontSize="12"
                                           Foreground="{DynamicResource AppTextMuted}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{svc:Loc Clean_StepPreview}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppTextMuted}"
                                           Margin="16,0"/>
                                <TextBlock Text="&#xE0AB;"
                                           FontFamily="{DynamicResource IconFont}"
                                           FontSize="12"
                                           Foreground="{DynamicResource AppTextMuted}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{svc:Loc Clean_StepConfirm}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppTextMuted}"
                                           Margin="16,0"/>
                                <TextBlock Text="&#xE0AB;"
                                           FontFamily="{DynamicResource IconFont}"
                                           FontSize="12"
                                           Foreground="{DynamicResource AppTextMuted}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{svc:Loc Clean_StepDone}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppTextMuted}"
                                           Margin="16,0"/>
                        </StackPanel>
                </StackPanel>

                <Grid Grid.Row="1"
                      Grid.RowSpan="2">
                        <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource EqInt}, ConverterParameter=1}">
                                <TextBlock Text="Choose cleaning preset"
                                           FontSize="16"
                                           
                                           Margin="0,0,0,12"/>
                                <UniformGrid Columns="3">
                                        <Border Style="{StaticResource Card}"
                                                Margin="0,0,8,0"
                                                Padding="20">
                                                <StackPanel>
                                                        <TextBlock Text="&#xE74D;"
                                                                   FontFamily="{DynamicResource IconFont}"
                                                                   FontSize="32"
                                                                   Foreground="{DynamicResource AppTextMuted}"/>
                                                        <TextBlock Text="Quick"
                                                                   FontSize="18"
                                                                   FontWeight="SemiBold"
                                                                   
                                                                   Margin="0,8,0,4"/>
                                                        <TextBlock Text="Temp, prefetch, thumbnail cache, browser cache, crash dumps"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{DynamicResource AppTextMuted}"/>
                                                        <RadioButton GroupName="Preset"
                                                                     Content="Select"
                                                                     Margin="0,12,0,0"
                                                                     
                                                                     IsChecked="{Binding SelectedPreset, Converter={StaticResource EnumEq}, ConverterParameter=Quick}"/>
                                                </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource Card}"
                                                Margin="4,0"
                                                Padding="20">
                                                <StackPanel>
                                                        <TextBlock Text="&#xE8FD;"
                                                                   FontFamily="{DynamicResource IconFont}"
                                                                   FontSize="32"
                                                                   Foreground="{DynamicResource AppTextMuted}"/>
                                                        <TextBlock Text="Deep"
                                                                   FontSize="18"
                                                                   FontWeight="SemiBold"
                                                                   
                                                                   Margin="0,8,0,4"/>
                                                        <TextBlock Text="Quick + Windows Update cache, old installers, large downloads"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{DynamicResource AppTextMuted}"/>
                                                        <RadioButton GroupName="Preset"
                                                                     Content="Select"
                                                                     Margin="0,12,0,0"
                                                                     
                                                                     IsChecked="{Binding SelectedPreset, Converter={StaticResource EnumEq}, ConverterParameter=Deep}"/>
                                                </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource Card}"
                                                Margin="8,0,0,0"
                                                Padding="20">
                                                <StackPanel>
                                                        <TextBlock Text="&#xEC7A;"
                                                                   FontFamily="{DynamicResource IconFont}"
                                                                   FontSize="32"
                                                                   Foreground="{DynamicResource AppTextMuted}"/>
                                                        <TextBlock Text="Developer"
                                                                   FontSize="18"
                                                                   FontWeight="SemiBold"
                                                                   
                                                                   Margin="0,8,0,4"/>
                                                        <TextBlock Text="node_modules, __pycache__, bin/obj, .next, .turbo, target"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{DynamicResource AppTextMuted}"/>
                                                        <RadioButton GroupName="Preset"
                                                                     Content="Select"
                                                                     Margin="0,12,0,0"
                                                                     
                                                                     IsChecked="{Binding SelectedPreset, Converter={StaticResource EnumEq}, ConverterParameter=Developer}"/>
                                                </StackPanel>
                                        </Border>
                                </UniformGrid>
                        </StackPanel>

                        <Border Style="{StaticResource Card}"
                                Padding="0"
                                Visibility="{Binding CurrentStep, Converter={StaticResource EqInt}, ConverterParameter=2}">
                                <DataGrid ItemsSource="{Binding Items}"
                                          AutoGenerateColumns="False"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="None"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          EnableRowVirtualization="True"
                                          RowHeight="30"
                                          >
                                        <DataGrid.Columns>
                                                <DataGridTemplateColumn Header=""
                                                                        Width="40">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                  IsEnabled="{Binding IsBlocked, Converter={StaticResource InvertBool}}"
                                                                                  HorizontalAlignment="Center"/>
                                                                </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header=""
                                                                        Width="8">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                        <Border Background="{Binding Risk, Converter={StaticResource RiskBrush}}"
                                                                                Width="4"
                                                                                HorizontalAlignment="Left"/>
                                                                </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="Name"
                                                                    Binding="{Binding Name}"
                                                                    Width="*"
                                                                    IsReadOnly="True"/>
                                                <DataGridTextColumn Header="Size"
                                                                    Binding="{Binding SizeBytes, Converter={StaticResource BytesToHuman}}"
                                                                    Width="90"
                                                                    IsReadOnly="True"/>
                                                <DataGridTextColumn Header="Category"
                                                                    Binding="{Binding Category}"
                                                                    Width="140"
                                                                    IsReadOnly="True"/>
                                                <DataGridTextColumn Header="Risk"
                                                                    Binding="{Binding Risk}"
                                                                    Width="90"
                                                                    IsReadOnly="True"/>
                                        </DataGrid.Columns>
                                </DataGrid>
                        </Border>

                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding CurrentStep, Converter={StaticResource EqInt}, ConverterParameter=3}">
                                <TextBlock Text="🛡️"
                                           FontSize="64"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Confirm quarantine"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           
                                           HorizontalAlignment="Center"
                                           Margin="0,16,0,8"/>
                                <TextBlock HorizontalAlignment="Center"
                                           Foreground="{DynamicResource AppTextMuted}"
                                           TextAlignment="Center">
                    <Run Text="Files will be moved to quarantine and retained 14 days."/>
                    <LineBreak/>
                    <Run Text="You can restore them anytime from the Quarantine page."/>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Margin="0,20,0,0">
                                        <TextBlock Text="{Binding SelectedCount, StringFormat={}{0} items}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   
                                                   Margin="0,0,16,0"/>
                                        <TextBlock Text="{Binding SelectedBytes, Converter={StaticResource BytesToHuman}}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AppTextMuted}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding ConfirmCountdown, StringFormat=Available in {0}s...}"
                                           HorizontalAlignment="Center"
                                           Margin="0,16,0,0"
                                           Foreground="{DynamicResource AppTextMuted}"
                                           Visibility="{Binding CanConfirm, Converter={StaticResource InvertVis}}"/>
                        </StackPanel>

                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding CurrentStep, Converter={StaticResource EqInt}, ConverterParameter=4}">
                                <TextBlock Text="âœ…"
                                           FontSize="64"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Cleaning complete"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           
                                           HorizontalAlignment="Center"
                                           Margin="0,16,0,8"/>
                                <TextBlock Text="{Binding Status}"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource AppTextMuted}"/>
                                <Button Content="Start over"
                                        Style="{StaticResource PrimaryBtn}"
                                        Margin="0,20,0,0"
                                        HorizontalAlignment="Center"
                                        Command="{Binding RestartCommand}"/>
                        </StackPanel>
                </Grid>

                <Grid Grid.Row="3"
                      Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Status}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppTextMuted}"/>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal">
                                <Button Style="{StaticResource SecondaryBtn}"
                                        Command="{Binding BackCommand}"
                                        IsEnabled="{Binding CurrentStep, Converter={StaticResource GreaterThan}, ConverterParameter=1}"
                                        Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE0A4;" FontFamily="{DynamicResource IconFont}" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Back" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource PrimaryBtn}"
                                        Command="{Binding NextCommand}"
                                        Visibility="{Binding CurrentStep, Converter={StaticResource LessThan}, ConverterParameter=3}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Next" VerticalAlignment="Center"/>
                                        <TextBlock Text="&#xE0AB;" FontFamily="{DynamicResource IconFont}" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource PrimaryBtn}"
                                        Command="{Binding ConfirmCommand}"
                                        Background="{DynamicResource AppDanger}"
                                        Visibility="{Binding CurrentStep, Converter={StaticResource EqInt}, ConverterParameter=3}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE10B;" FontFamily="{DynamicResource IconFont}" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Confirm" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                        </StackPanel>
                </Grid>
        </Grid>
</Page>
