<Window x:Class="WinVitals.App.Views.CommandPaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:WinVitals.App.Converters"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Width="640"
        Height="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <conv:NonEmptyVisConverter x:Key="NonEmptyVis"/>
    </Window.Resources>
    <Border Background="#F0181825"
            CornerRadius="8"
            BorderBrush="#40FFFFFF"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24"
                    ShadowDepth="0"
                    Opacity="0.6"/>
        </Border.Effect>
        <Grid Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBox Grid.Row="0"
                    x:Name="QueryBox"
                     Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="18"
                    Background="Transparent"
                    BorderThickness="0"
                     
                    Padding="16,14"/>
            <ListBox Grid.Row="1"
                    ItemsSource="{Binding ItemsView}"
                    SelectedItem="{Binding SelectedItem}"
                     Background="Transparent"
                    BorderThickness="0"
                    
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding"
                                Value="16,8"/>
                        <Setter Property="Background"
                                Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected"
                                    Value="True">
                                <Setter Property="Background"
                                        Value="#3089B4FA"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"
                                        FontWeight="SemiBold"
                                        Opacity="0.6"
                                           Foreground="{DynamicResource AppTextMuted}"
                                        Padding="16,6,0,2"
                                        FontSize="11"/>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListBox.GroupStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding IconGlyph}"
                                    Width="20"
                                    TextAlignment="Center"
                                    Margin="0,0,12,0"
                                    Opacity="0.7"/>
                            <TextBlock Grid.Column="1"
                                    Text="{Binding Title}"
                                    VerticalAlignment="Center"/>
                            <Border Grid.Column="2"
                                    Background="#20FFFFFF"
                                    CornerRadius="4"
                                    Padding="6,2"
                                    Visibility="{Binding Shortcut, Converter={StaticResource NonEmptyVis}}">
                                <TextBlock Text="{Binding Shortcut}"
                                        FontFamily="Cascadia Mono, Consolas"
                                        FontSize="11"
                                        Opacity="0.7"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</Window>
