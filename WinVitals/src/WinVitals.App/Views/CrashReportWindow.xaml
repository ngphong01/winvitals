<Window x:Class="WinVitals.App.Views.CrashReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinVitals ran into a problem"
        Width="640"
        Height="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="#F0181825"
            CornerRadius="8"
            BorderBrush="#40FFFFFF"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24"
                    ShadowDepth="0"
                    Opacity="0.6"/>
        </Border.Effect>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="0,0,0,16">
                <TextBlock Text="âš "
                        FontSize="32"
                        Foreground="#F38BA8"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Something went wrong"
                            FontSize="22"
                            FontWeight="SemiBold"
                            />
                    <TextBlock Text="WinVitals encountered an unexpected error."
                            Foreground="{DynamicResource AppTextMuted}"/>
                </StackPanel>
            </StackPanel>

            <TextBlock Grid.Row="1"
                    TextWrapping="Wrap"
                    Margin="0,0,0,12"
                    Foreground="#BAC2DE"
                    FontSize="13">
                You can help us fix this by sending an anonymous report. It contains only the error
                type, stack trace hash, and app version. No file paths, file content, or personal data.
            </TextBlock>

            <Border Grid.Row="2"
                    Background="#0AFFFFFF"
                    CornerRadius="6"
                    Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="DetailsText"
                            FontFamily="Cascadia Mono, Consolas"
                            FontSize="11"
                               
                            TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>

            <CheckBox Grid.Row="3"
                    x:Name="IncludeLogsCheck"
                    Content="Include recent log excerpt in report"
                      IsChecked="True"
                    Margin="0,12,0,0"
                    Foreground="{DynamicResource AppTextMuted}"/>

            <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
                <Button Content="ðŸ“‚ Open folder"
                        Style="{StaticResource SecondaryBtn}"
                        Click="OpenFolder_Click"
                        Margin="0,0,8,0"
                        Padding="12,6"/>
                <Button Content="Don't send"
                        Style="{StaticResource SecondaryBtn}"
                        Click="Ignore_Click"
                        Margin="0,0,8,0"
                        Padding="12,6"/>
                <Button Content="ðŸ“¤ Send report"
                        Style="{StaticResource PrimaryBtn}"
                        Click="Send_Click"
                        Padding="12,6"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
