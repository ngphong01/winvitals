<Page x:Class="WinVitals.App.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="clr-namespace:WinVitals.App.Converters"
      xmlns:ctrl="clr-namespace:WinVitals.App.Controls"
      xmlns:svc="clr-namespace:WinVitals.App.Services"
      Title="Dashboard">
    <Page.Resources>
        <conv:BytesToHumanConverter x:Key="BytesToHuman"/>
        <conv:InvertBoolConverter x:Key="InvertBool"/>
        <conv:NonEmptyVisConverter x:Key="NonEmptyVis"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{svc:Loc Page_Dashboard}"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Margin="0,0,0,16"/>

            <!-- Top cards -->
            <UniformGrid Grid.Row="1"
                         Columns="3"
                         Margin="0,0,0,16">
                <Border Style="{StaticResource Card}"
                        Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="{svc:Loc Dash_HealthScore}"
                                   Foreground="{DynamicResource AppTextMuted}"/>
                        <TextBlock Text="{Binding HealthScore, StringFormat={}{0}/100}"
                                   FontSize="32"
                                   FontWeight="Bold"/>
                        <ProgressBar Value="{Binding HealthScore}"
                                     Maximum="100"
                                     Height="6"
                                     Foreground="#60A5FA"
                                     Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}"
                        Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="{svc:Loc Dash_CPU}"
                                   Foreground="{DynamicResource AppTextMuted}"/>
                        <TextBlock Text="{Binding CpuPercent, StringFormat={}{0:0.0}%}"
                                   FontSize="32"
                                   FontWeight="Bold"/>
                        <ProgressBar Value="{Binding CpuPercent}"
                                     Maximum="100"
                                     Height="6"
                                     Foreground="#A78BFA"
                                     Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}"
                        Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{svc:Loc Dash_RAM}"
                                   Foreground="{DynamicResource AppTextMuted}"/>
                        <TextBlock Text="{Binding RamPercent, StringFormat={}{0:0.0}%}"
                                   FontSize="32"
                                   FontWeight="Bold"/>
                        <ProgressBar Value="{Binding RamPercent}"
                                     Maximum="100"
                                     Height="6"
                                     Foreground="#34D399"
                                     Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- System Info -->
            <Border Grid.Row="2"
                    Style="{StaticResource Card}"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="System Information"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>
                    <UniformGrid Columns="2"
                                 HorizontalAlignment="Left">
                        <StackPanel Margin="0,2">
                            <TextBlock Text="Machine Name"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    FontSize="12"/>
                            <TextBlock Text="{Binding SysInfo.MachineName}"
                                    FontWeight="SemiBold"
                                    FontSize="14"
                                    Margin="0,2,0,6"/>
                        </StackPanel>
                        <StackPanel Margin="0,2">
                            <TextBlock Text="User"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    FontSize="12"/>
                            <TextBlock Text="{Binding SysInfo.UserName}"
                                    FontWeight="SemiBold"
                                    FontSize="14"
                                    Margin="0,2,0,6"/>
                        </StackPanel>
                        <StackPanel Margin="0,2">
                            <TextBlock Text="OS"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    FontSize="12"/>
                            <TextBlock Text="{Binding SysInfo.OsVersion}"
                                    FontWeight="SemiBold"
                                    FontSize="14"
                                    Margin="0,2,0,6"
                                    TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <StackPanel Margin="0,2">
                            <TextBlock Text="Architecture"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    FontSize="12"/>
                            <TextBlock Text="{Binding SysInfo.OsArchitecture}"
                                    FontWeight="SemiBold"
                                    FontSize="14"
                                    Margin="0,2,0,6"/>
                        </StackPanel>
                        <StackPanel Margin="0,2">
                            <TextBlock Text="CPU"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    FontSize="12"/>
                            <TextBlock Text="{Binding SysInfo.CpuName}"
                                    FontWeight="SemiBold"
                                    FontSize="14"
                                    Margin="0,2,0,6"
                                    TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <StackPanel Margin="0,2">
                            <TextBlock Text="Cores / Threads"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    FontSize="12"/>
                            <TextBlock FontWeight="SemiBold"
                                    FontSize="14"
                                    Margin="0,2,0,6">
                                <Run Text="{Binding SysInfo.CpuCores}"/> cores / <Run Text="{Binding SysInfo.CpuLogicalProcessors}"/> threads
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Margin="0,2">
                            <TextBlock Text="Total RAM"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    FontSize="12"/>
                            <TextBlock FontWeight="SemiBold"
                                    FontSize="14"
                                    Margin="0,2,0,6">
                                <Run Text="{Binding SysInfo.RamTotalGb, StringFormat={}{0:0.0}}"/> GB
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Margin="0,2">
                            <TextBlock Text="GPU"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    FontSize="12"/>
                            <TextBlock Text="{Binding SysInfo.GpuName}"
                                    FontWeight="SemiBold"
                                    FontSize="14"
                                    Margin="0,2,0,6"
                                    TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <StackPanel Margin="0,2">
                            <TextBlock Text=".NET Runtime"
                                    Foreground="{DynamicResource AppTextMuted}"
                                    FontSize="12"/>
                            <TextBlock Text="{Binding SysInfo.DotNetVersion}"
                                    FontWeight="SemiBold"
                                    FontSize="14"
                                    Margin="0,2,0,6"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- Drives -->
            <Border Grid.Row="3"
                    Style="{StaticResource Card}"
                    Margin="0,0,0,16">
                <StackPanel>
                    <Grid>
                        <TextBlock Text="{svc:Loc Dash_Drives}"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                        <Button Content="Refresh"
                                Style="{StaticResource SecondaryBtn}"
                                HorizontalAlignment="Right"
                                Padding="10,6"
                                Command="{Binding RefreshDrivesCommand}"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Drives}"
                                  Margin="0,12,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card}"
                                        Margin="4"
                                        Padding="12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="💾 "
                                                       FontSize="16"/>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Label}"
                                                   Foreground="{DynamicResource AppTextMuted}"
                                                   Margin="0,2,0,6"/>
                                        <ProgressBar Value="{Binding UsedPercent}"
                                                     Maximum="100"
                                                     Height="6"/>
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="{DynamicResource AppTextMuted}"
                                                   FontSize="12">
                                            <Run Text="{Binding FreeBytes, Converter={StaticResource BytesToHuman}}"/>
                                            <Run Text=" free of "/>
                                            <Run Text="{Binding TotalBytes, Converter={StaticResource BytesToHuman}}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding DriveFormat}"
                                                   Foreground="{DynamicResource AppTextMuted}"
                                                   FontSize="11"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- SMART -->
            <Border Grid.Row="4"
                    Style="{StaticResource Card}">
                <StackPanel>
                    <Grid>
                        <TextBlock Text="{svc:Loc Dash_DiskHealth}"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                        <Button Content="Refresh"
                                Style="{StaticResource SecondaryBtn}"
                                HorizontalAlignment="Right"
                                Padding="10,6"
                                Command="{Binding LoadSmartCommand}"
                                IsEnabled="{Binding IsLoadingSmart, Converter={StaticResource InvertBool}}"/>
                    </Grid>
                    <DataGrid ItemsSource="{Binding SmartDrives}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              Background="Transparent"
                              BorderThickness="0"
                              Margin="0,12,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Model"
                                                Binding="{Binding Model}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Interface"
                                                Binding="{Binding InterfaceType}"
                                                Width="100"/>
                            <DataGridTextColumn Header="Status"
                                                Binding="{Binding Status}"
                                                Width="100"/>
                            <DataGridTemplateColumn Header="Health"
                                                    Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text"
                                                            Value="âœ… Healthy"/>
                                                    <Setter Property="Foreground"
                                                            Value="#A6E3A1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PredictFailure}"
                                                                     Value="True">
                                                            <Setter Property="Text"
                                                                    Value="âš  Predicted failure"/>
                                                            <Setter Property="Foreground"
                                                                    Value="#F38BA8"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Serial"
                                                Binding="{Binding SerialNumber}"
                                                Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
