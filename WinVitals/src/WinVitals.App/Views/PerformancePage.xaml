<Page x:Class="WinVitals.App.Views.PerformancePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      xmlns:conv="clr-namespace:WinVitals.App.Converters"
      xmlns:svc="clr-namespace:WinVitals.App.Services"
      Title="Performance">
    <Page.Resources>
        <conv:BytesToHumanConverter x:Key="BytesToHuman"/>
    </Page.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{svc:Loc Page_Performance}"
                FontSize="28"
                FontWeight="SemiBold"
                   
                Margin="0,0,0,16"/>

        <!-- Metrics cards -->
        <UniformGrid Grid.Row="1"
                Columns="3"
                Margin="0,0,0,16">
            <Border Style="{StaticResource Card}"
                    Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="CPU"
                            Foreground="{DynamicResource AppTextMuted}"/>
                    <TextBlock Text="{Binding CpuNow, StringFormat={}{0:0.0}%}"
                               FontSize="28"
                            FontWeight="Bold"
                            Foreground="#60A5FA"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}"
                    Margin="4,0">
                <StackPanel>
                    <TextBlock Text="RAM"
                            Foreground="{DynamicResource AppTextMuted}"/>
                    <TextBlock FontSize="28"
                            FontWeight="Bold"
                            Foreground="#A78BFA">
                        <Run Text="{Binding RamUsedGb, StringFormat={}{0:0.0}}"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding RamTotalGb, StringFormat={}{0:0.0} GB}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}"
                    Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Health"
                            Foreground="{DynamicResource AppTextMuted}"/>
                    <TextBlock Text="{Binding HealthScore}"
                            FontSize="28"
                            FontWeight="Bold"
                               Foreground="#34D399"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Chart -->
        <Border Grid.Row="2"
                Style="{StaticResource Card}"
                Padding="8"
                Height="220"
                Margin="0,0,0,16">
            <lvc:CartesianChart
                Series="{Binding Series}"
                XAxes="{Binding XAxes}"
                YAxes="{Binding YAxes}"
                LegendPosition="Top"/>
        </Border>

        <!-- Process list -->
        <Border Grid.Row="3"
                Style="{StaticResource Card}"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Grid Grid.Row="0"
                        Margin="12,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                            Text="Processes"
                            FontWeight="SemiBold"
                               
                            VerticalAlignment="Center"
                            Margin="0,0,16,0"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding Processes.Filter, UpdateSourceTrigger=PropertyChanged, Delay=200}"
                            
                            BorderThickness="0"
                             Padding="8,4"
                            FontSize="13"/>
                    <CheckBox Grid.Column="2"
                            Content="Hide system"
                              IsChecked="{Binding Processes.HideSystem}"
                              Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource AppTextMuted}"/>
                    <TextBlock Grid.Column="3"
                               Text="{Binding Processes.TotalCount, StringFormat={}{0} items}"
                               Margin="16,0,0,0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource AppTextMuted}"/>
                </Grid>

                <!-- Data grid -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Processes.RowsView}"
                          AutoGenerateColumns="False"
                        IsReadOnly="True"
                          HeadersVisibility="Column"
                        GridLinesVisibility="None"
                          Background="Transparent"
                        BorderThickness="0"
                          EnableRowVirtualization="True"
                        RowHeight="28"
                          >
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="End task"
                                      Command="{Binding PlacementTarget.DataContext.Processes.EndTaskCommand,
                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem,
                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            <MenuItem Header="Open file location"
                                      Command="{Binding PlacementTarget.DataContext.Processes.OpenLocationCommand,
                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem,
                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name"
                                Binding="{Binding Name}"
                                Width="220"/>
                        <DataGridTextColumn Header="PID"
                                Binding="{Binding Pid}"
                                Width="70"/>
                        <DataGridTextColumn Header="CPU"
                                            Binding="{Binding CpuPercent, StringFormat={}{0:0.0}%}"
                                Width="80"/>
                        <DataGridTextColumn Header="Memory"
                                            Binding="{Binding WorkingSet, Converter={StaticResource BytesToHuman}}"
                                Width="100"/>
                        <DataGridTextColumn Header="Threads"
                                Binding="{Binding Threads}"
                                Width="80"/>
                        <DataGridTextColumn Header="Publisher"
                                Binding="{Binding Publisher}"
                                Width="180"/>
                        <DataGridTextColumn Header="Description"
                                Binding="{Binding Description}"
                                Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>
