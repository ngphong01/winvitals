<Page x:Class="WinVitals.App.Views.QuarantinePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="clr-namespace:WinVitals.App.Converters"
      xmlns:ctrl="clr-namespace:WinVitals.App.Controls"
      xmlns:svc="clr-namespace:WinVitals.App.Services"
      Title="Quarantine"
      Background="#1E1E2E">
        <Page.Resources>
                <conv:BytesToHumanConverter x:Key="BytesToHuman"/>
        </Page.Resources>

        <Grid Margin="24">
                <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="{svc:Loc Page_Quarantine}"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Margin="0,0,0,16"/>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            Margin="0,0,0,16">
                        <Button Content="{svc:Loc Quar_Refresh}"
                                Style="{StaticResource SecondaryBtn}"
                                Command="{Binding RefreshCommand}"
                                Margin="0,0,8,0"/>
                        <Button Content="{svc:Loc Quar_Restore}"
                                Style="{StaticResource PrimaryBtn}"
                                Command="{Binding RestoreSelectedCommand}"
                                Margin="0,0,8,0"/>
                        <Button Content="{svc:Loc Quar_Purge}"
                                Style="{StaticResource PrimaryBtn}"
                                Background="#F38BA8"
                                Command="{Binding PurgeSelectedCommand}"
                                Margin="0,0,8,0"/>
                        <Button Content="{svc:Loc Quar_PurgeExpired}"
                                Style="{StaticResource SecondaryBtn}"
                                Command="{Binding PurgeExpiredCommand}"/>
                </StackPanel>

                <Border Grid.Row="2"
                        Style="{StaticResource Card}"
                        Padding="0">
                        <Grid>
                                <DataGrid ItemsSource="{Binding Entries}"
                                          SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="None"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          RowHeight="32"
                                          x:Name="QuarantineGrid">
                                        <DataGrid.Columns>
                                                <DataGridTextColumn Header="Original Path"
                                                                    Binding="{Binding OriginalPath}"
                                                                    Width="*"/>
                                                <DataGridTextColumn Header="Size"
                                                                    Binding="{Binding SizeBytes, Converter={StaticResource BytesToHuman}}"
                                                                    Width="90"/>
                                                <DataGridTextColumn Header="Risk"
                                                                    Binding="{Binding Risk}"
                                                                    Width="90"/>
                                                <DataGridTextColumn Header="Quarantined"
                                                                    Binding="{Binding QuarantinedAtUtc, StringFormat=yyyy-MM-dd HH:mm}"
                                                                    Width="140"/>
                                                <DataGridTextColumn Header="Expires"
                                                                    Binding="{Binding ExpiresAtUtc, StringFormat=yyyy-MM-dd HH:mm}"
                                                                    Width="140"/>
                                                <DataGridTextColumn Header="Reason"
                                                                    Binding="{Binding Reason}"
                                                                    Width="200"/>
                                        </DataGrid.Columns>
                                </DataGrid>

                                <!-- Empty state -->
                                <ctrl:EmptyStateControl x:Name="QuarantineEmpty"
                                                        IconGlyph="&#xE72E;"
                                                        Title="Nothing quarantined yet"
                                                        Description="Run a scan and clean to quarantine files."
                                                        Visibility="Collapsed"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"/>
                        </Grid>
                </Border>

                <StatusBar Grid.Row="3"
                           Margin="0,12,0,0"
                           Background="Transparent"
                           Foreground="{DynamicResource AppTextMuted}">
                        <TextBlock Text="{Binding Status}"/>
                        <Separator/>
                        <TextBlock>
                <Run Text="Total in quarantine:"/>
                <Run Text="{Binding TotalBytes, Converter={StaticResource BytesToHuman}}"
                                FontWeight="SemiBold"/>
                        </TextBlock>
                </StatusBar>
        </Grid>
</Page>
