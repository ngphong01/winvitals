<Page x:Class="WinVitals.App.Views.RulesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="clr-namespace:WinVitals.App.Converters"
      xmlns:ctrl="clr-namespace:WinVitals.App.Controls"
      xmlns:svc="clr-namespace:WinVitals.App.Services"
      Title="Rules">
    <Page.Resources>
        <conv:RiskToBrushConverter x:Key="RiskBrush"/>
        <conv:BytesToHumanConverter x:Key="BytesToHuman"/>
        <conv:NotNullConverter x:Key="NotNull"/>
        <conv:NonEmptyVisConverter x:Key="NonEmptyVis"/>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{svc:Loc Page_Rules}"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

        <!-- Toolbar -->
        <Grid Grid.Row="1"
              Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     BorderThickness="0"
                     Padding="8,4"
                     Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged, Delay=200}"/>
            <CheckBox Grid.Column="1"
                      Content="{svc:Loc Rules_ShowBuiltIn}"
                      IsChecked="{Binding ShowBuiltIn}"
                      Margin="12,0,0,0"
                      VerticalAlignment="Center"
                      Foreground="{DynamicResource AppTextMuted}"/>
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Margin="12,0,0,0">
                <Button Content="{svc:Loc Rules_New}"
                        Style="{StaticResource PrimaryBtn}"
                        Command="{Binding NewCommand}"
                        Margin="0,0,4,0"
                        Padding="10,6"/>
                <Button Content="{svc:Loc Rules_Edit}"
                        Style="{StaticResource SecondaryBtn}"
                        Command="{Binding EditCommand}"
                        Margin="0,0,4,0"
                        Padding="10,6"/>
                <Button Content="Dup"
                        Style="{StaticResource SecondaryBtn}"
                        Command="{Binding DuplicateCommand}"
                        Margin="0,0,4,0"
                        Padding="10,6"/>
                <Button Content="{svc:Loc Rules_Delete}"
                        Style="{StaticResource SecondaryBtn}"
                        Command="{Binding DeleteCommand}"
                        Margin="0,0,4,0"
                        Padding="10,6"
                        Background="#F38BA8"/>
                <Button Content="Export"
                        Style="{StaticResource SecondaryBtn}"
                        Command="{Binding ExportCommand}"
                        Margin="0,0,4,0"
                        Padding="10,6"/>
                <Button Content="Import"
                        Style="{StaticResource SecondaryBtn}"
                        Command="{Binding ImportCommand}"
                        Padding="10,6"/>
            </StackPanel>
        </Grid>

        <!-- Body: Grid + right panel -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Rules grid -->
            <Border Grid.Column="0"
                    Style="{StaticResource Card}"
                    Padding="0"
                    Margin="0,0,12,0">
                <Grid>
                    <DataGrid ItemsSource="{Binding RulesView}"
                              SelectedItem="{Binding SelectedRule, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              Background="Transparent"
                              BorderThickness="0"
                              RowHeight="34"
                              CanUserSortColumns="True">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="On"
                                                    Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay}"
                                                  HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header=""
                                                    Width="8">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding Risk, Converter={StaticResource RiskBrush}}"
                                                Width="4"
                                                HorizontalAlignment="Left"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Id"
                                                Binding="{Binding Id}"
                                                Width="160"
                                                FontFamily="Cascadia Mono, Consolas"
                                                IsReadOnly="True"/>
                            <DataGridTextColumn Header="Name"
                                                Binding="{Binding Name}"
                                                Width="*"
                                                IsReadOnly="True"/>
                            <DataGridTextColumn Header="Pri"
                                                Binding="{Binding Priority}"
                                                Width="50"
                                                IsReadOnly="True"/>
                            <DataGridTextColumn Header="Action"
                                                Binding="{Binding Action}"
                                                Width="100"
                                                IsReadOnly="True"/>
                            <DataGridTextColumn Header="Risk"
                                                Binding="{Binding Risk}"
                                                Width="80"
                                                IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Kind"
                                                    Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4"
                                                Padding="6,2">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background"
                                                            Value="#3A506B"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsBuiltIn}"
                                                                     Value="True">
                                                            <Setter Property="Background"
                                                                    Value="#FAB387"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="10"
                                                       FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text"
                                                                Value="Custom"/>
                                                        <Setter Property="Foreground"
                                                                Value="White"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsBuiltIn}"
                                                                         Value="True">
                                                                <Setter Property="Text"
                                                                        Value="System"/>
                                                                <Setter Property="Foreground"
                                                                        Value="Black"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty state -->
                    <ctrl:EmptyStateControl x:Name="RulesEmpty"
                                            IconGlyph="&#xE16F;"
                                            Title="No matching rules"
                                            Description="Clear the filter or create a new rule."
                                            ActionText="Clear filter"
                                            Visibility="Collapsed"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Right panel -->
            <Grid Grid.Column="1">
                <!-- Test panel -->
                <Border Padding="16">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background"
                                    Value="#313244"/>
                            <Setter Property="CornerRadius"
                                    Value="8"/>
                            <Setter Property="Visibility"
                                    Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Editor, Converter={StaticResource NotNull}}"
                                             Value="True">
                                    <Setter Property="Visibility"
                                            Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="Rule test runner"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>
                        <TextBlock Foreground="{DynamicResource AppTextMuted}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,12">
                            Evaluate all rules against a hypothetical file to see which one wins.
                        </TextBlock>
                        <TextBlock Text="File path"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Margin="0,4,0,4"/>
                        <TextBox Text="{Binding TestPath, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0"
                                 Padding="6,4"
                                 FontFamily="Cascadia Mono, Consolas"/>
                        <TextBlock Text="File size (bytes)"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Margin="0,10,0,4"/>
                        <TextBox Text="{Binding TestSizeText, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0"
                                 Padding="6,4"/>
                        <TextBlock Text="Age (days)"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   Margin="0,10,0,4"/>
                        <TextBox Text="{Binding TestAgeText, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0"
                                 Padding="6,4"/>
                        <Button Content="Evaluate"
                                Style="{StaticResource PrimaryBtn}"
                                Margin="0,16,0,0"
                                HorizontalAlignment="Stretch"
                                Command="{Binding RunTestCommand}"/>
                        <Border Background="#20FFFFFF"
                                CornerRadius="6"
                                Padding="12"
                                Margin="0,12,0,0">
                            <TextBlock Text="{Binding TestResult}"
                                       FontFamily="Cascadia Mono, Consolas"
                                       TextWrapping="Wrap"
                                       MinHeight="80"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Editor panel -->
                <Border Padding="16">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background"
                                    Value="#313244"/>
                            <Setter Property="CornerRadius"
                                    Value="8"/>
                            <Setter Property="Visibility"
                                    Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Editor, Converter={StaticResource NotNull}}"
                                             Value="True">
                                    <Setter Property="Visibility"
                                            Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel DataContext="{Binding Editor}">
                            <TextBlock Text="{Binding Title}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="Id"
                                       Foreground="{DynamicResource AppTextMuted}"
                                       Margin="0,4,0,4"/>
                            <TextBox Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsNew}"
                                     BorderThickness="0"
                                     Padding="6,4"
                                     FontFamily="Cascadia Mono, Consolas"/>

                            <TextBlock Text="Name"
                                       Foreground="{DynamicResource AppTextMuted}"
                                       Margin="0,8,0,4"/>
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     Padding="6,4"/>

                            <TextBlock Text="Description"
                                       Foreground="{DynamicResource AppTextMuted}"
                                       Margin="0,8,0,4"/>
                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     Padding="6,4"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MinHeight="50"/>

                            <TextBlock Text="Priority (0-199)"
                                       Foreground="{DynamicResource AppTextMuted}"
                                       Margin="0,8,0,4"/>
                            <TextBox Text="{Binding Priority, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     Padding="6,4"/>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0"
                                            Margin="0,0,4,0">
                                    <TextBlock Text="Action"
                                               Foreground="{DynamicResource AppTextMuted}"
                                               Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding AllActions}"
                                              SelectedItem="{Binding Action}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Margin="4,0,0,0">
                                    <TextBlock Text="Risk"
                                               Foreground="{DynamicResource AppTextMuted}"
                                               Margin="0,0,0,4"/>
                                    <ComboBox ItemsSource="{Binding AllRisks}"
                                              SelectedItem="{Binding Risk}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Preset"
                                       Foreground="{DynamicResource AppTextMuted}"
                                       Margin="0,8,0,4"/>
                            <ComboBox ItemsSource="{Binding AllPresets}"
                                      SelectedItem="{Binding Preset}"/>

                            <TextBlock Text="Path patterns (one per line)"
                                       Foreground="{DynamicResource AppTextMuted}"
                                       Margin="0,12,0,4"/>
                            <TextBox Text="{Binding PathPatternsText, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     Padding="6,4"
                                     FontFamily="Cascadia Mono, Consolas"
                                     AcceptsReturn="True"
                                     MinHeight="80"/>

                            <TextBlock Text="Extensions (comma-separated)"
                                       Foreground="{DynamicResource AppTextMuted}"
                                       Margin="0,8,0,4"/>
                            <TextBox Text="{Binding ExtensionsText, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     Padding="6,4"
                                     FontFamily="Cascadia Mono, Consolas"/>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0"
                                            Margin="0,0,4,0">
                                    <TextBlock Text="Min size (MB)"
                                               Foreground="{DynamicResource AppTextMuted}"
                                               Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding MinSizeMB, UpdateSourceTrigger=PropertyChanged}"
                                             BorderThickness="0"
                                             Padding="6,4"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Margin="4,0,0,0">
                                    <TextBlock Text="Max age (days)"
                                               Foreground="{DynamicResource AppTextMuted}"
                                               Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding MaxAgeDays, UpdateSourceTrigger=PropertyChanged}"
                                             BorderThickness="0"
                                             Padding="6,4"/>
                                </StackPanel>
                            </Grid>

                            <CheckBox Content="Enabled"
                                      IsChecked="{Binding Enabled}"
                                      Margin="0,12,0,0"
                                      Foreground="{DynamicResource AppTextMuted}"/>

                            <TextBlock Text="{Binding Errors}"
                                       Foreground="#F38BA8"
                                       TextWrapping="Wrap"
                                       Margin="0,12,0,0"
                                       Visibility="{Binding Errors, Converter={StaticResource NonEmptyVis}}"/>

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,16,0,0"
                                        HorizontalAlignment="Right">
                                <Button Content="Cancel"
                                        Style="{StaticResource SecondaryBtn}"
                                        Command="{Binding CancelCommand}"
                                        Margin="0,0,8,0"
                                        Padding="10,6"/>
                                <Button Content="Save"
                                        Style="{StaticResource PrimaryBtn}"
                                        Command="{Binding SaveCommand}"
                                        Padding="10,6"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
