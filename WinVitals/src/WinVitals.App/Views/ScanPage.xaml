<Page x:Class="WinVitals.App.Views.ScanPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="clr-namespace:WinVitals.App.Converters"
      xmlns:ctrl="clr-namespace:WinVitals.App.Controls"
      xmlns:svc="clr-namespace:WinVitals.App.Services"
      xmlns:enums="clr-namespace:WinVitals.Core;assembly=WinVitals.Core"
      xmlns:system="clr-namespace:System;assembly=System.Runtime"
      Title="Scan">
    <Page.Resources>
        <conv:BytesToHumanConverter x:Key="BytesToHuman"/>
        <conv:RiskToBrushConverter x:Key="RiskBrush"/>
        <ObjectDataProvider x:Key="PresetValues"
                            MethodName="GetValues"
                            ObjectType="{x:Type system:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="enums:ScanPreset"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Page.Resources>

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page title -->
        <TextBlock Text="{svc:Loc Page_Scan}"
                   FontSize="26"
                   FontWeight="SemiBold"
                   Foreground="#CDD6F4"
                   Margin="0,0,0,20"/>

        <!-- Controls bar -->
        <Border Grid.Row="1"
                Background="#2A2A3C"
                CornerRadius="8"
                Padding="16,12"
                Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="{svc:Loc Scan_Preset}"
                               VerticalAlignment="Center"
                               Foreground="#A6ADC8"
                               FontSize="13"
                               Margin="0,0,10,0"/>
                    <ComboBox ItemsSource="{Binding Source={StaticResource PresetValues}}"
                              SelectedItem="{Binding SelectedPreset}"
                              Width="150"
                              VerticalContentAlignment="Center"
                              Margin="0,0,16,0">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem"
                                   BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding}"
                                                 Value="{x:Static enums:ScanPreset.Quick}">
                                        <Setter Property="ToolTip"
                                                Value="Quick scan of common locations: temp files, browser cache, logs"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding}"
                                                 Value="{x:Static enums:ScanPreset.Deep}">
                                        <Setter Property="ToolTip"
                                                Value="Deep scan of entire system: all drives, large files, duplicates"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding}"
                                                 Value="{x:Static enums:ScanPreset.Developer}">
                                        <Setter Property="ToolTip"
                                                Value="Developer cleanup: build artifacts, node_modules, NuGet/package caches"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>
                </StackPanel>

                <Button Content="START SCAN"
                        Width="120"
                        Height="38"
                        Background="#89B4FA"
                        Foreground="#1E1E2E"
                        FontWeight="Bold"
                        FontSize="14"
                        Cursor="Hand"
                        Margin="0,0,8,0"
                        Click="BtnStart_Click"/>
                <Button Content="CANCEL"
                        Width="100"
                        Height="38"
                        Background="#45475A"
                        Foreground="#CDD6F4"
                        FontSize="14"
                        Cursor="Hand"
                        Click="BtnCancel_Click"/>
                <Button Content="GO TO CLEAN →"
                        Width="130"
                        Height="38"
                        Background="#A6E3A1"
                        Foreground="#1E1E2E"
                        FontWeight="Bold"
                        FontSize="13"
                        Cursor="Hand"
                        Click="BtnGoClean_Click"
                        Visibility="{Binding Items.Count, Converter={StaticResource NonEmptyVis}}"/>
            </StackPanel>
        </Border>

        <!-- Scan progress panel -->
        <Border Grid.Row="2"
                Background="#2A2A3C"
                CornerRadius="8"
                Padding="16,12"
                Margin="0,0,0,12"
                Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Scanning…"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#89B4FA"
                               Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Items scanned: "
                                   Foreground="#A6ADC8"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding TotalItems}"
                                   Foreground="#CDD6F4"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="   Found: "
                                   Foreground="#A6ADC8"
                                   FontSize="12"
                                   Margin="16,0,0,0"/>
                        <TextBlock Text="{Binding FoundSizeText}"
                                   Foreground="#CDD6F4"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock Foreground="#585B70"
                               FontSize="11"
                               Margin="0,3,0,0"
                               TextTrimming="CharacterEllipsis">
                        <Run Text="Current: "/>
                        <Run Text="{Binding CurrentPath}"/>
                    </TextBlock>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding ElapsedText}"
                           Foreground="#A6ADC8"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>
            </Grid>
        </Border>

        <!-- Results area -->
        <Border Grid.Row="3"
                Style="{StaticResource Card}"
                Padding="0">
            <Grid>
                <DataGrid ItemsSource="{Binding Items}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          AlternationCount="2"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False">
                    <DataGrid.Columns>
                        <!-- Risk indicator -->
                        <DataGridTemplateColumn Width="6"
                                                CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding Risk, Converter={StaticResource RiskBrush}}"
                                            Width="3"
                                            CornerRadius="2"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Stretch"
                                            Margin="0,3"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Name -->
                        <DataGridTextColumn Header="Name"
                                            Binding="{Binding Name}"
                                            Width="*"
                                            MinWidth="160">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextTrimming"
                                            Value="CharacterEllipsis"/>
                                    <Setter Property="ToolTip"
                                            Value="{Binding Path}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Size -->
                        <DataGridTextColumn Header="Size"
                                            Binding="{Binding SizeBytes, Converter={StaticResource BytesToHuman}}"
                                            Width="85">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment"
                                            Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Category -->
                        <DataGridTextColumn Header="Category"
                                            Binding="{Binding Category}"
                                            Width="140"/>

                        <!-- Risk -->
                        <DataGridTextColumn Header="Risk"
                                            Binding="{Binding Risk}"
                                            Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment"
                                            Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Action -->
                        <DataGridTextColumn Header="Action"
                                            Binding="{Binding RecommendedAction}"
                                            Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment"
                                            Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Rule -->
                        <DataGridTextColumn Header="Rule"
                                            Binding="{Binding MatchedRuleId}"
                                            Width="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily"
                                            Value="Cascadia Mono, Consolas, monospace"/>
                                    <Setter Property="FontSize"
                                            Value="12"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty state -->
                <ctrl:EmptyStateControl x:Name="ScanEmpty"
                                        IconGlyph="&#xE294;"
                                        Title="{svc:Loc Scan_Ready}"
                                        Description="{svc:Loc Scan_ReadyDesc}"
                                        Visibility="Collapsed"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Status bar -->
        <StatusBar Grid.Row="4"
                   Margin="0,10,0,0"
                   Background="Transparent"
                   Foreground="#A6ADC8"
                   FontSize="12">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <TextBlock Grid.Column="0"
                       Text="{Binding Status}"
                       Foreground="#CDD6F4"
                       FontWeight="Medium"/>
            <Separator Grid.Column="1"
                       Margin="12,2"/>
            <TextBlock Grid.Column="2"
                       Foreground="#A6ADC8">
                <Run Text="Items: "/>
                <Run Text="{Binding TotalItems}"
                     FontWeight="SemiBold"
                     Foreground="#CDD6F4"/>
            </TextBlock>
            <Separator Grid.Column="3"
                       Margin="12,2"/>
            <TextBlock Grid.Column="4"
                       Foreground="#A6ADC8">
                <Run Text="Total: "/>
                <Run Text="{Binding TotalBytes, Converter={StaticResource BytesToHuman}}"
                     FontWeight="SemiBold"
                     Foreground="#CDD6F4"/>
            </TextBlock>
        </StatusBar>
    </Grid>
</Page>
