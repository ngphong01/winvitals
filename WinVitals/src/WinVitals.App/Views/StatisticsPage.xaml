<Page x:Class="WinVitals.App.Views.StatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      xmlns:conv="clr-namespace:WinVitals.App.Converters"
      xmlns:ctrl="clr-namespace:WinVitals.App.Controls"
      xmlns:svc="clr-namespace:WinVitals.App.Services"
      Title="Statistics">
    <Page.Resources>
        <conv:BytesToHumanConverter x:Key="BytesToHuman"/>
        <conv:InsightKindToBrushConverter x:Key="InsightBrush"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <!-- Header -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{svc:Loc Page_Statistics}"
                           FontSize="28"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AllRanges}"
                          SelectedItem="{Binding SelectedRange}"
                          Width="150"
                          Margin="0,0,8,0"/>
                <Button Grid.Column="2"
                        Content="Refresh"
                        Style="{StaticResource SecondaryBtn}"
                        Command="{Binding RefreshCommand}"
                        Padding="10,6"/>
            </Grid>

            <!-- KPI cards -->
            <UniformGrid Columns="4"
                         Margin="0,0,0,16">
                <Border Style="{StaticResource Card}"
                        Margin="0,0,6,0"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="{svc:Loc Stats_TotalReclaimed}"
                                   Foreground="{DynamicResource AppTextMuted}"/>
                        <TextBlock Text="{Binding TotalBytesEver, Converter={StaticResource BytesToHuman}}"
                                   FontSize="26"
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding TotalSessionsEver, StringFormat={}{0} sessions}"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}"
                        Margin="3,0"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="{svc:Loc Stats_ThisMonth}"
                                   Foreground="{DynamicResource AppTextMuted}"/>
                        <TextBlock Text="{Binding BytesThisMonth, Converter={StaticResource BytesToHuman}}"
                                   FontSize="26"
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding MonthTrendText}"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}"
                        Margin="3,0"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="{svc:Loc Stats_InQuarantine}"
                                   Foreground="{DynamicResource AppTextMuted}"/>
                        <TextBlock Text="{Binding QuarantineBytesNow, Converter={StaticResource BytesToHuman}}"
                                   FontSize="26"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Recoverable"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}"
                        Margin="6,0,0,0"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="{svc:Loc Stats_CurrentStreak}"
                                   Foreground="{DynamicResource AppTextMuted}"/>
                        <TextBlock FontSize="26"
                                   FontWeight="Bold">
                            <Run Text="{Binding CurrentStreak}"/><Run Text=" days"/>
                        </TextBlock>
                        <TextBlock Text="Consecutive days"
                                   Foreground="{DynamicResource AppTextMuted}"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Bytes trend chart -->
            <Border Style="{StaticResource Card}"
                    Padding="16"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Bytes reclaimed over time"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>
                    <lvc:CartesianChart Height="240"
                                        Series="{Binding BytesTrendSeries}"
                                        XAxes="{Binding TrendXAxes}"
                                        YAxes="{Binding TrendYAxes}"
                                        LegendPosition="Hidden"/>
                </StackPanel>
            </Border>

            <!-- Day of week + Category pie -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Style="{StaticResource Card}"
                        Padding="16"
                        Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="Cleanups by day of week"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>
                        <lvc:CartesianChart Height="220"
                                            Series="{Binding DayOfWeekSeries}"
                                            XAxes="{Binding DayXAxes}"
                                            YAxes="{Binding DayYAxes}"
                                            LegendPosition="Hidden"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1"
                        Style="{StaticResource Card}"
                        Padding="16"
                        Margin="6,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Bytes by category"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>
                        <lvc:PieChart Height="220"
                                      Series="{Binding CategorySeries}"
                                      LegendPosition="Right"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Insights -->

            <!-- Empty state -->
            <ctrl:EmptyStateControl x:Name="StatsEmpty"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    IconGlyph="&#xE9D9;"
                                    Title="No data yet"
                                    Description="Run your first clean to see statistics here."
                                    ActionText="Go to Scan"
                                    Visibility="Collapsed"
                                    Margin="0,40,0,0"/>

            <TextBlock Text="Insights"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,8,0,12"/>
            <ItemsControl ItemsSource="{Binding Insights}"
                          Margin="0,0,0,16">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}"
                                Margin="4"
                                Padding="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="36"
                                        Height="36"
                                        CornerRadius="18"
                                        Background="{Binding Kind, Converter={StaticResource InsightBrush}}"
                                        VerticalAlignment="Top"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="{Binding Icon}"
                                               FontSize="18"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="White"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Title}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Description}"
                                               Foreground="{DynamicResource AppTextMuted}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Recent sessions table -->
            <TextBlock Text="Recent cleanups"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,8,0,12"/>
            <Border Style="{StaticResource Card}"
                    Padding="0">
                <DataGrid ItemsSource="{Binding RecentSessions}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          Background="Transparent"
                          BorderThickness="0"
                          RowHeight="32">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="When"
                                            Binding="{Binding CompletedAtUtc, StringFormat=yyyy-MM-dd HH:mm}"
                                            Width="140"/>
                        <DataGridTextColumn Header="Preset"
                                            Binding="{Binding Preset}"
                                            Width="90"/>
                        <DataGridTemplateColumn Header="Source"
                                                Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text"
                                                        Value="Manual"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding WasScheduled}"
                                                                 Value="True">
                                                        <Setter Property="Text"
                                                                Value="Scheduled"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Items"
                                            Binding="{Binding QuarantinedCount}"
                                            Width="70"/>
                        <DataGridTextColumn Header="Freed"
                                            Binding="{Binding BytesFreed, Converter={StaticResource BytesToHuman}}"
                                            Width="100"/>
                        <DataGridTextColumn Header="Skipped"
                                            Binding="{Binding SkippedCount}"
                                            Width="80"/>
                        <DataGridTextColumn Header="Failed"
                                            Binding="{Binding FailedCount}"
                                            Width="80"/>
                        <DataGridTextColumn Header="Elapsed"
                                            Binding="{Binding Elapsed, StringFormat=mm\\:ss}"
                                            Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
