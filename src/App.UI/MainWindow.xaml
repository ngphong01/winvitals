<Window x:Class="AppUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows Health Manager"
        Height="800" Width="1200" MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#16161E"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <Window.Resources>

        <!-- ===== BRUSHES & COLOR SYSTEM ===== -->
        <SolidColorBrush x:Key="SidebarBg" Color="#13131A"/>
        <SolidColorBrush x:Key="MainBg" Color="#16161E"/>
        <SolidColorBrush x:Key="SurfaceBg" Color="#1C1D2E"/>
        <SolidColorBrush x:Key="SurfaceAlt" Color="#222338"/>
        <SolidColorBrush x:Key="CardBg" Color="#1A1B2E"/>
        <SolidColorBrush x:Key="CardBorder" Color="#2A2B42"/>
        <SolidColorBrush x:Key="Accent" Color="#7C96F0"/>
        <SolidColorBrush x:Key="AccentGlow" Color="#4C66C0"/>
        <SolidColorBrush x:Key="Success" Color="#9ECE6A"/>
        <SolidColorBrush x:Key="Warning" Color="#E0AF68"/>
        <SolidColorBrush x:Key="Error" Color="#F7768E"/>
        <SolidColorBrush x:Key="Info" Color="#7DCFFF"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E2E4F0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#9B9DB8"/>
        <SolidColorBrush x:Key="TextMuted" Color="#5D5F7A"/>
        <SolidColorBrush x:Key="NavHover" Color="#1E1F35"/>
        <SolidColorBrush x:Key="NavActive" Color="#252748"/>
        <SolidColorBrush x:Key="NavActiveIndicator" Color="#7C96F0"/>
        <SolidColorBrush x:Key="OverlayBg" Color="#8016161E"/>

        <!-- Gradient brushes for depth -->
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#7C96F0" Offset="0"/>
            <GradientStop Color="#A78BFA" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="SuccessGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#9ECE6A" Offset="0"/>
            <GradientStop Color="#7DCFFF" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="SidebarGlow" StartPoint="1,0" EndPoint="0,0">
            <GradientStop Color="#2A2B42" Offset="0"/>
            <GradientStop Color="#13131A" Offset="1"/>
        </LinearGradientBrush>

        <!-- ===== SIDEBAR NAV BUTTON ===== -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="24,0,0,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="3,0,0,0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}"
                                TextBlock.FontWeight="Normal"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource NavHover}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ===== NAV SECTION HEADER ===== -->
        <Style x:Key="NavSection" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Margin" Value="20,16,0,4"/>
        </Style>

        <!-- ===== CARD ===== -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#3B3D5A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ===== CARD MINI (for dashboard stats row) ===== -->
        <Style x:Key="CardMini" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Padding" Value="16"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1" Color="#000000" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== PRIMARY BUTTON ===== -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.7"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ===== SECONDARY BUTTON (outline style) ===== -->
        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="{StaticResource SurfaceAlt}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== DANGER BUTTON ===== -->
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="{StaticResource Error}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>

        <!-- ===== SUCCESS BUTTON (Quick Clean, Clean Dev) ===== -->
        <Style x:Key="SuccessBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="{StaticResource Success}"/>
            <Setter Property="Foreground" Value="#13131A"/>
        </Style>

        <!-- ===== WARNING BUTTON ===== -->
        <Style x:Key="WarningBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="{StaticResource Warning}"/>
            <Setter Property="Foreground" Value="#13131A"/>
        </Style>

        <!-- ===== PAGE TITLE / SUB-HEADER STYLES ===== -->
        <Style x:Key="PageTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="PageDesc" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="StatusText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- ===== TOOLBAR STACKPANEL ===== -->
        <Style x:Key="Toolbar" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- ===== CATEGORY CARD STYLE (for DevClean category badges) ===== -->
        <Style x:Key="CategoryCard" TargetType="Border" BasedOn="{StaticResource CardMini}">
            <Setter Property="Width" Value="145"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <!-- ===== FILTER CHECKBOX STYLE ===== -->
        <Style x:Key="FilterCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ===== DEV CACHE ITEM TEXT ===== -->
        <Style x:Key="DevItemName" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>
        <Style x:Key="DevItemSub" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        </Style>

        <!-- ===== LISTBOX MODERN ===== -->
        <Style x:Key="ModernListBox" TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ScrollViewer Focusable="False" Padding="2">
                                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== COMBOBOX MODERN ===== -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource SurfaceAlt}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="12.5"/>
        </Style>

        <!-- ===== TEXTBOX MODERN ===== -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SurfaceAlt}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="CaretBrush" Value="{StaticResource Accent}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== SCROLLBAR MODERN ===== -->
        <Style x:Key="ModernScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- ===== EMPTY TEXTBLOCK ===== -->
        <Style x:Key="EmptyText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontStyle" Value="Italic"/>
        </Style>

        <!-- ===== SECTION TITLE ===== -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,20,0,8"/>
        </Style>

        <!-- ===== SIDEBAR NAV SEPARATOR ===== -->
        <Style x:Key="NavSeparator" TargetType="Separator">
            <Setter Property="Background" Value="{StaticResource CardBorder}"/>
            <Setter Property="Margin" Value="16,8"/>
            <Setter Property="Height" Value="1"/>
        </Style>
    </Window.Resources>

    <!-- ===== MAIN LAYOUT ===== -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo Area -->
                <Border Grid.Row="0" BorderBrush="#2A2B42" BorderThickness="0,0,0,1" Padding="16,14,20,12">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Vector Logo Icon -->
                        <Viewbox Width="32" Height="32" Margin="0,0,10,0" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <!-- Shield base -->
                                <Path Data="M12,2 L4,6 L4,12 C4,17 7.5,21.5 12,23 C16.5,21.5 20,17 20,12 L20,6 Z"
                                      Fill="#1E2640" Stroke="{StaticResource Accent}" StrokeThickness="1.2"/>
                                <!-- Shield inner highlight -->
                                <Path Data="M12,4 L6,7.5 L6,12 C6,16 8.5,19.5 12,21 C15.5,19.5 18,16 18,12 L18,7.5 Z"
                                      Fill="Transparent" Stroke="{StaticResource Accent}" StrokeThickness="0.5" Opacity="0.3"/>
                                <!-- Heartbeat line -->
                                <Polyline Points="7,12 9.5,12 10.5,9 11.5,15 12.8,11 14,11 15,13 17,13"
                                          Stroke="{StaticResource Success}" StrokeThickness="1.5"
                                          StrokeLineJoin="Round"
                                          Fill="Transparent"/>
                                <!-- Small dot accent -->
                                <Ellipse Canvas.Left="16" Canvas.Top="3" Width="2.5" Height="2.5"
                                         Fill="{StaticResource Success}" Opacity="0.8"/>
                            </Canvas>
                        </Viewbox>
                        <!-- Logo Text -->
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Windows Health" FontSize="14" FontWeight="SemiBold"
                                      Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="System Manager" FontSize="9.5" Foreground="{StaticResource TextMuted}"
                                      Margin="0,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Navigation -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" Margin="0,4,0,0">
                    <StackPanel>
                        <TextBlock Text="MAIN" Style="{StaticResource NavSection}"/>
                        <Button x:Name="BtnDashboard" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Dashboard">
                            <Button.Content><StackPanel Orientation="Horizontal"><TextBlock Text="◈ " FontSize="13"/><TextBlock Text="Bảng Điều Khiển"/></StackPanel></Button.Content>
                        </Button>
                        <Button x:Name="BtnDisk" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Disk">
                            <Button.Content><StackPanel Orientation="Horizontal"><TextBlock Text="▣ " FontSize="13"/><TextBlock Text="Phân Tích Ổ Đĩa"/></StackPanel></Button.Content>
                        </Button>
                        <Button x:Name="BtnCleaner" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Cleaner">
                            <Button.Content><StackPanel Orientation="Horizontal"><TextBlock Text="◇ " FontSize="13"/><TextBlock Text="Dọn Dẹp"/></StackPanel></Button.Content>
                        </Button>

                        <TextBlock Text="TOOLS" Style="{StaticResource NavSection}"/>
                        <Button x:Name="BtnLargeFiles" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="LargeFiles">
                            <Button.Content><StackPanel Orientation="Horizontal"><TextBlock Text="△ " FontSize="13"/><TextBlock Text="File Lớn"/></StackPanel></Button.Content>
                        </Button>
                        <Button x:Name="BtnOrphan" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Orphan">
                            <Button.Content><StackPanel Orientation="Horizontal"><TextBlock Text="◎ " FontSize="13"/><TextBlock Text="File Mồ Côi"/></StackPanel></Button.Content>
                        </Button>
                        <Button x:Name="BtnDuplicates" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Duplicate">
                            <Button.Content><StackPanel Orientation="Horizontal"><TextBlock Text="◐ " FontSize="13"/><TextBlock Text="File Trùng"/></StackPanel></Button.Content>
                        </Button>

                        <TextBlock Text="DEVELOPER" Style="{StaticResource NavSection}"/>
                        <Button x:Name="BtnDevClean" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="DevClean">
                            <Button.Content><StackPanel Orientation="Horizontal"><TextBlock Text="⊘ " FontSize="13"/><TextBlock Text="Cache Dev"/></StackPanel></Button.Content>
                        </Button>
                        <Button x:Name="BtnPerf" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Performance">
                            <Button.Content><StackPanel Orientation="Horizontal"><TextBlock Text="◉ " FontSize="13"/><TextBlock Text="Hiệu Năng"/></StackPanel></Button.Content>
                        </Button>
                        <Button x:Name="BtnStartup" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Startup">
                            <Button.Content><StackPanel Orientation="Horizontal"><TextBlock Text="▷ " FontSize="13"/><TextBlock Text="Khởi Động"/></StackPanel></Button.Content>
                        </Button>

                        <TextBlock Text="SYSTEM" Style="{StaticResource NavSection}"/>
                        <Button x:Name="BtnQuarantine" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Quarantine">
                            <Button.Content><StackPanel Orientation="Horizontal"><TextBlock Text="◻ " FontSize="13"/><TextBlock Text="Cách Ly"/></StackPanel></Button.Content>
                        </Button>
                        <Button x:Name="BtnRules" Style="{StaticResource NavBtn}" Click="Nav_Click" Tag="Rules">
                            <Button.Content><StackPanel Orientation="Horizontal"><TextBlock Text="⚙ " FontSize="13"/><TextBlock Text="Quy Tắc"/></StackPanel></Button.Content>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <!-- Sidebar Stats -->
                <Border Grid.Row="2" Background="#0C0C12" BorderBrush="#2A2B42" BorderThickness="0,1,0,0" Padding="16,12">
                    <TextBlock x:Name="TxtSidebarStats" FontSize="10.5" Foreground="{StaticResource TextMuted}"
                              LineHeight="18" TextWrapping="Wrap"/>
                </Border>
            </Grid>
        </Border>

        <!-- ===== MAIN CONTENT ===== -->
        <Border Grid.Column="1" Background="{StaticResource MainBg}">
            <Grid>
                <!-- Dashboard View -->
                <ScrollViewer x:Name="DashboardView" Visibility="Visible">
                    <StackPanel Margin="28,24">
                        <!-- Dashboard Header -->
                        <TextBlock Text="Bảng Điều Khiển" FontSize="22" FontWeight="SemiBold"
                                  Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Tổng quan hệ thống" FontSize="12.5" Foreground="{StaticResource TextSecondary}"
                                  Margin="0,2,0,20"/>

                        <!-- Drive usage text -->
                        <TextBlock x:Name="TxtDrives" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                  Margin="0,0,0,4" TextWrapping="Wrap" FontFamily="Consolas, monospace"/>

                                                    <!-- Stats Cards Row — clean metric cards -->
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Health Score -->
                                <Border Grid.Column="0" Style="{StaticResource CardMini}" Margin="0,0,6,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="{StaticResource Success}" CornerRadius="2" Margin="0,0,12,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Sức Khỏe Hệ Thống" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock x:Name="TxtScore" FontSize="28" FontWeight="Bold" Foreground="{StaticResource Success}"/>
                                                <TextBlock Text="/100" FontSize="14" Foreground="{StaticResource TextMuted}" Margin="4,6,0,0"/>
                                            </StackPanel>
                                            <TextBlock x:Name="TxtHealthLabel" Text="Tốt" FontSize="11" Foreground="{StaticResource Success}" Margin="0,1,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Tốtal Freed -->
                                <Border Grid.Column="1" Style="{StaticResource CardMini}" Margin="6,0,6,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="{StaticResource Accent}" CornerRadius="2" Margin="0,0,12,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Đã Giải Phóng" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                                            <TextBlock x:Name="TxtTotalFreed" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,4,0,1"/>
                                            <TextBlock Text="Tổng dung lượng đã dọn" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Quarantine Count -->
                                <Border Grid.Column="2" Style="{StaticResource CardMini}" Margin="6,0,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="{StaticResource Warning}" CornerRadius="2" Margin="0,0,12,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Đang Cách Ly" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                                            <TextBlock x:Name="TxtQuarantinedDash" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Warning}" Margin="0,4,0,1"/>
                                            <TextBlock Text="Items trong quarantine" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>                        <!-- Issues Section -->
                        <TextBlock Text="Vấn Đề" Style="{StaticResource SectionTitle}"/>
                        <Border Style="{StaticResource Card}" Padding="14" Margin="0,0,0,0">
                            <ItemsControl x:Name="IssuesList" />
                        </Border>

                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="Quét Toàn Bộ" Style="{StaticResource PrimaryBtn}"
                                    Width="140" Margin="0,0,8,0" Click="FullScan_Click"/>
                            <Button Content="Dọn Nhanh" Style="{StaticResource SuccessBtn}"
                                    Width="120" Margin="0,0,8,0"
                                    Click="QuickClean_Click"/>
                            <Button Content="Kiểm Tra" Style="{StaticResource SecondaryBtn}"
                                    Width="120" Click="PerfCheck_Click"/>
                        </StackPanel>

                        <!-- Recent Activity -->
                        <TextBlock Text="Hoạt Động Gần Đây" Style="{StaticResource SectionTitle}"/>
                        <Border Style="{StaticResource Card}" Padding="14">
                            <ItemsControl x:Name="RecentList" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Sub Pages View -->
                <ScrollViewer x:Name="PageView" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="PagePanel" Margin="28,24"/>
                </ScrollViewer>

                <!-- Loading Overlay -->
                <Border x:Name="LoadingOverlay" Background="{StaticResource OverlayBg}" Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse Width="36" Height="36" Stroke="{StaticResource Accent}"
                                 StrokeThickness="3" StrokeDashArray="50,20"
                                 Margin="0,0,0,16" HorizontalAlignment="Center"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform x:Name="SpinnerRotate" Angle="0"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Angle"
                                                              From="0" To="360" Duration="0:0:1.2"
                                                              RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <TextBlock x:Name="TxtLoading" Text="Đang xử lý..." FontSize="14"
                                  Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"
                                  Margin="0,0,0,12"/>
                        <ProgressBar x:Name="ScanProgress" Width="240" Height="4"
                                    Foreground="{StaticResource Accent}" Background="{StaticResource SurfaceBg}"
                                    BorderThickness="0" IsIndeterminate="True"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
